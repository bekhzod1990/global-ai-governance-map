{
  "name": "global-ai-governance-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "validate:data": "vitest run src/utils/validateData.test.ts src/utils/governanceTaxonomy.test.ts",
    "validate:export": "vitest run src/utils/exportDataset.test.ts src/utils/datasetSchema.test.ts",
    "audit:sources": "node scripts/audit-sources.mjs",
    "test:e2e": "node ./scripts/run-playwright.mjs",
    "test:a11y": "node ./scripts/run-playwright.mjs tests/e2e/a11y.spec.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "overrides": {
    "d3-color": "^3.1.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/d3-force": "^3.0.10",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-geo": "^3.1.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-simple-maps": "^3.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
